rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Marchés ─────────────────────────────────────────────────────────────
    // Lecture publique. Écriture réservée aux admins (champ isAdmin sur l'user).
    match /markets/{marketId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();

      match /options/{optionId} {
        allow read: if true;
        allow write: if request.auth != null && isAdmin();
      }

      match /priceHistory/{entryId} {
        allow read: if true;
        // Seul le backend (via amm.js dans une transaction) écrit l'historique —
        // on l'autorise pour tout user connecté car c'est toujours déclenché
        // par une transaction atomique (placeBet / sellShares) qui valide tout.
        allow write: if request.auth != null;
      }
    }

    // ── Soumissions de marchés ───────────────────────────────────────────────
    // Un user peut créer une soumission et relire les siennes.
    // Seul un admin peut modifier/supprimer.
    match /submissions/{submissionId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // ── Paris ────────────────────────────────────────────────────────────────
    // Lecture : chaque user voit seulement ses propres paris.
    // Création : uniquement avec son propre userId (jamais usurper quelqu'un d'autre).
    // Pas de modification ni suppression côté client.
    match /bets/{betId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Positions (compteur de parts détenues) ───────────────────────────────
    // Lecture/écriture uniquement par le propriétaire de la position.
    // L'ID du document est {userId}_{marketId}_{side|optionId}.
    // On extrait le userId directement depuis l'ID du document plutôt que
    // depuis resource.data, car resource est null si le document n'existe
    // pas encore (cas normal : l'utilisateur n'a jamais eu de position ici).
    match /positions/{positionId} {
      allow read: if request.auth != null &&
        positionId.split('_')[0] == request.auth.uid;
      allow write: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        positionId.split('_')[0] == request.auth.uid;
    }

    // ── Utilisateurs ─────────────────────────────────────────────────────────
    // Lecture publique (leaderboard, profils).
    // Écriture uniquement sur son propre document.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Notifications ────────────────────────────────────────────────────────
    // Lecture/écriture uniquement par le destinataire.
    match /notifications/{notifId} {
      allow read, write: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // ── Fonction helper ──────────────────────────────────────────────────────
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
